[{"ayah":1,"text":"Say, \\\"He is Allāh, [who is] One,","tl":"Qul huwal laahu ahad"},{"ayah":2,"text":"Allāh, the Eternal Refuge.","tl":"Allah-hus samad"},{"ayah":3,"text":"He neither begets nor is born,","tl":"Lam yalid Wa-lam yoolad"},{"ayah":4,"text":"Nor is there to Him any equivalent.\\\"","tl":"Wa-lam yakul lahoo kufuwan ahad"}]